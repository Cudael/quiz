# Database
DATABASE_URL="postgresql://username:password@host:5432/database_name?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
AUTH_SECRET=""

# Public site URL — used for OG images, canonical URLs, and sitemaps.
# Defaults to VERCEL_URL on Vercel. Set explicitly for custom domains.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Public legal identity shown in the Privacy Policy and Terms of Service.
# Use the individual or registered business that operates BusQuiz and an address
# at which legal/privacy correspondence can be received.
NEXT_PUBLIC_LEGAL_NAME=""
NEXT_PUBLIC_LEGAL_ADDRESS=""

# Play token signing secret — used to sign quiz play tokens.
# If unset, AUTH_SECRET is used; in production one of these MUST be set.
# Generate with: npx auth secret
PLAY_TOKEN_SECRET=""

# OAuth providers (optional for guest play)
# Email/password sign-in needs no OAuth keys, but registration needs the Gmail
# settings below so users can receive the required verification link.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Gmail SMTP. Authenticate with the paid hello@ mailbox; account and support
# addresses can be Google Workspace aliases on that same user.
# Enable 2FA on hello@busquiz.com, then generate an App Password.
# If not set, verification/reset emails are logged to console in dev/test mode.
GMAIL_USER="hello@busquiz.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"
EMAIL_ACCOUNTS_FROM="BusQuiz Accounts <accounts@busquiz.com>"
EMAIL_GENERAL_FROM="BusQuiz <hello@busquiz.com>"
EMAIL_SUPPORT_REPLY_TO="BusQuiz Support <support@busquiz.com>"

# Cron job secret — used to authenticate /api/cron/* endpoints.
# Generate with: npx auth secret
CRON_SECRET=""

# Optional stretch features
OPENAI_API_KEY=""

# Google Analytics 4 (optional)
# Create a GA4 property at https://analytics.google.com/ and copy the Measurement ID.
# When configured, BusQuiz shows consent controls and does not request GA before opt-in.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Add only after AdSense assigns the complete ca-pub-XXXXXXXXXXXXXXXX identifier.
# This enables the ownership meta tag and /ads.txt; it does not load advertising scripts.
GOOGLE_ADSENSE_PUBLISHER_ID=""

# Cloudflare R2 image storage (private bucket + Worker for public serving)
# Deploy the Worker in worker/src/index.ts via: npm run worker:deploy
# Then connect a custom domain in the Cloudflare dashboard (e.g. images.busquiz.com)
# and set R2_PUBLIC_URL to that domain.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""   # Custom domain of the Cloudflare Worker (e.g. https://images.busquiz.com)

# Upstash Redis — enables shared rate-limit counters and play-token nonce
# tracking across serverless instances.
# REQUIRED for production: without Redis, rate limits and replay protection
# degrade to per-instance in-memory stores that can be bypassed across
# serverless instances. Requests that need either safeguard fail in production
# when these variables are absent.
# Create a database at https://console.upstash.com and copy the REST credentials.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
