# Database
DATABASE_URL="postgresql://neondb_owner:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
AUTH_SECRET=""

# OAuth providers (optional for guest play)
# Email/password auth needs no extra env vars beyond DATABASE_URL + AUTH_SECRET.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional stretch features
OPENAI_API_KEY=""
BLOB_READ_WRITE_TOKEN=""   # Vercel Blob token — get from Vercel dashboard > Storage > Blob
