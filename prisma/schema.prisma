generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  SINGLE
  TRUEFALSE
  FILL_BLANK
  MAP_SELECT
  HOTSPOT
}

enum QuizFormat {
  TEXT_CHOICE
  IMAGE_CHOICE
  MAP_CHOICE
  IMAGE_HOTSPOT
}


enum DuelStatus {
  WAITING
  IN_PROGRESS
  FINISHED
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  INCORRECT_ANSWERS
  COPYRIGHT
  OTHER
}

enum ReportStatus {
  PENDING
  DISMISSED
  ACTIONED
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  BADGE_EARNED
  NEW_FOLLOWER
  QUIZ_PLAYED
}

model User {
  id            String    @id @default(cuid())
  name          String
  username      String?   @unique
  email         String?   @unique
  passwordHash  String?
  bio           String?
  bannerImage   String?
  preferences   Json? // UserPreferences object
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  xp            Int       @default(0)
  level         Int       @default(1)
  streakDays    Int       @default(0)
  bestStreak    Int       @default(0)
  lastPlayedAt  DateTime?
  createdAt     DateTime  @default(now())

  quizzes             Quiz[]               @relation("AuthoredQuizzes")
  categories          Category[]           @relation("CreatedCategories")
  sessions            PlaySession[]
  badges              UserBadge[]
  followers           Follow[]             @relation("Followers")
  following           Follow[]             @relation("Following")
  reports             Report[]             @relation("ReportedBy")
  categorySuggestions CategorySuggestion[] @relation("SuggestedBy")
  accounts            Account[]
  authSessions        Session[]
  adminActions        AdminAction[]        @relation("AdminActionActor")
  favoriteQuizzes     FavoriteQuiz[]       @relation("FavoriteQuizzes")
  notifications       Notification[]
  hostedDuels         Duel[]               @relation("HostedDuels")
  duelParticipations  DuelParticipant[]    @relation("DuelParticipations")
  ratings             Rating[]
  feedback            Feedback[]
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  color       String
  imageUrl    String?
  parentSlug  String?
  createdById String?
  createdBy   User?    @relation("CreatedCategories", fields: [createdById], references: [id])
  quizzes     Quiz[]
  duels       Duel[]
  createdAt   DateTime @default(now())
}

model Quiz {
  id                  String     @id @default(cuid())
  title               String
  slug                String?    @unique
  description         String
  coverImage          String?
  tags                String[] // string array, e.g. ["history","ww2"]
  categoryId          String
  category            Category   @relation(fields: [categoryId], references: [id])
  difficulty          Difficulty @default(MEDIUM)
  authorId            String
  author              User       @relation("AuthoredQuizzes", fields: [authorId], references: [id])
  isPublished         Boolean    @default(true)
  playCount           Int        @default(0)
  avgScore            Float      @default(0)
  defaultTimeLimitSec Int?
  format              QuizFormat @default(TEXT_CHOICE)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  questions   Question[]
  sessions    PlaySession[]
  reports     Report[]
  favoritedBy FavoriteQuiz[] @relation("FavoritedBy")
  ratings     Rating[]

  @@index([categoryId])
  @@index([authorId])
}

model Rating {
  userId    String
  quizId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  stars     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, quizId])
  @@index([quizId])
}

model Question {
  id           String       @id @default(cuid())
  quizId       String
  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type         QuestionType @default(SINGLE)
  prompt       String
  imageUrl     String?
  explanation  String?
  timeLimitSec Int          @default(20)
  points       Int          @default(1)
  order        Int
  meta         Json?

  choices Choice[]
  answers QuestionAnswer[]

  @@index([quizId])
}

model Choice {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  imageUrl   String?
  isCorrect  Boolean  @default(false)
  meta       Json?

  @@index([questionId])
}

model PlaySession {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  guestName    String?
  guestKey     String?
  quizId       String
  quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score        Int
  correctCount Int
  totalCount   Int
  timeTakenMs  Int
  createdAt    DateTime @default(now())
  answers      QuestionAnswer[]

  @@index([quizId])
  @@index([userId])
  @@index([guestKey])
  @@index([createdAt])
}

model Duel {
  id            String            @id @default(cuid())
  code          String            @unique
  hostId        String
  host          User              @relation("HostedDuels", fields: [hostId], references: [id])
  categoryId    String?
  category      Category?         @relation(fields: [categoryId], references: [id])
  questionCount Int               @default(10)
  timeLimitSec  Int               @default(20)
  status        DuelStatus        @default(WAITING)
  createdAt     DateTime          @default(now())
  finishedAt    DateTime?
  participants  DuelParticipant[]
}

model DuelParticipant {
  id           String    @id @default(cuid())
  duelId       String
  duel         Duel      @relation(fields: [duelId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?     @relation("DuelParticipations", fields: [userId], references: [id])
  guestName    String?
  guestKey     String?
  score        Int       @default(0)
  correctCount Int       @default(0)
  finished     Boolean   @default(false)
  finishedAt   DateTime?
  joinedAt     DateTime  @default(now())

  @@index([duelId])
  @@index([userId])
}

model QuestionAnswer {
  id          String      @id @default(cuid())
  sessionId   String
  session     PlaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  chosenIds   String[] // array of selected choice IDs
  isCorrect   Boolean
  timeTakenMs Int

  @@index([sessionId])
  @@index([questionId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Badge {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  icon        String
  criteria    Json // e.g. { "type": "streak", "days": 7 }

  awards UserBadge[]
}

model UserBadge {
  userId    String
  badgeId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@id([userId, badgeId])
}

model Follow {
  followerId  String
  followingId String
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}

model FavoriteQuiz {
  userId    String
  quizId    String
  user      User     @relation("FavoriteQuizzes", fields: [userId], references: [id], onDelete: Cascade)
  quiz      Quiz     @relation("FavoritedBy", fields: [quizId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, quizId])
  @@index([userId])
  @@index([quizId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  meta      Json? // extra context (e.g. badgeId, followerId)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

model Report {
  id           String       @id @default(cuid())
  quizId       String
  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  reporterId   String?
  reporter     User?        @relation("ReportedBy", fields: [reporterId], references: [id])
  reason       ReportReason
  details      String?
  status       ReportStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  resolvedAt   DateTime?
  resolvedById String?

  @@index([quizId])
  @@index([status])
}

model CategorySuggestion {
  id            String           @id @default(cuid())
  name          String
  description   String
  icon          String
  color         String
  suggestedById String
  suggestedBy   User             @relation("SuggestedBy", fields: [suggestedById], references: [id])
  status        SuggestionStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  reviewedAt    DateTime?
  reviewedById  String?
}

model AdminAction {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation("AdminActionActor", fields: [actorId], references: [id], onDelete: Cascade)
  action     String
  targetType String
  targetId   String
  meta       Json // extra context for the action
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

enum FeedbackType {
  BUG_REPORT
  FEATURE_REQUEST
  GENERAL_FEEDBACK
  CONTENT_ISSUE
}

enum FeedbackStatus {
  PENDING
  REVIEWED
  RESOLVED
}

model Feedback {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         FeedbackType
  message      String
  email        String?
  status       FeedbackStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  reviewedAt   DateTime?
  reviewedById String?

  @@index([status])
  @@index([userId])
}
